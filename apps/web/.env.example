# Supabase (web app - Vite exposes VITE_ prefixed vars)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: Map tiles for routes map + fleet map.
# Without these, maps show a coordinate fallback list instead of an interactive map.
# For local dev, public OpenStreetMap tiles work. For production, use your own provider.
# VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
# VITE_MAP_TILE_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors
