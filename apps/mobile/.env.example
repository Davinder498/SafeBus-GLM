# SafeBus Mobile App — Environment Variables
#
# Copy this file to .env and fill in values from your Supabase project settings.
# These are the SAME values used by the web app (apps/web/.env).
#
# Privacy: Only VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are used.
# NEVER put a service_role key or any secret key here.

# Supabase project URL (Hosted DEV for smoke testing)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for client-side use; protected by RLS)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Deployed SafeBus web app URL — used for email deep-links (password reset)
# so links open in a browser, not inside the native app.
# Example: https://safebus-alberta.netlify.app
VITE_APP_ORIGIN=https://your-safebus-web-app-url.example.ca