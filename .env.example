# Root developer tooling only. Do not commit real values.

# Hosted Supabase DEV or disposable migrated Postgres database URL.
# Never use production. Never use frontend anon keys here.
SAFEBUS_RLS_TEST_DATABASE_URL=postgresql://postgres.example:REPLACE_ME@db.example.supabase.co:5432/postgres

# Required guard for `pnpm test:rls:dev`.
SAFEBUS_RLS_TEST_CONFIRM=DEV_ONLY

# Optional for local disposable databases only. Hosted Supabase should use SSL.
# SAFEBUS_RLS_TEST_SSL=disable
