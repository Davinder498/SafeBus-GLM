{
  "name": "@safebus/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI component library for SafeBus Alberta.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
    "./components/*": "./src/components/*/index.tsx"
